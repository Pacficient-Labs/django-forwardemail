{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits",
    "schedule:weekly"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "internalChecksFilter": "strict",
  "minimumReleaseAge": "3 days",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": false,
    "schedule": ["before 5am on monday"]
  },
  "packageRules": [
    {
      "description": "Automerge dev/test/lint/build tooling (dev and docs extras are dev-only; PEP 621 emits depType project.optional-dependencies, plus PEP 735 dependency-groups)",
      "matchDepTypes": ["project.optional-dependencies", "dependency-groups"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "automerge": true
    },
    {
      "description": "Automerge non-major updates for stable (>=1.0.0) runtime dependencies",
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "description": "Automerge GitHub Actions minor, patch and digest updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "automerge": true
    },
    {
      "description": "Never automerge the PyPI publish action: it only runs on release and is not exercised by the PR test workflow",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["pypa/gh-action-pypi-publish"],
      "automerge": false
    },
    {
      "description": "Require Dependency Dashboard approval for all major updates and never automerge them",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "automerge": false
    }
  ]
}
